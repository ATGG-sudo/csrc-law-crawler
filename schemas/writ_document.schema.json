{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "body": {
      "type": "string"
    },
    "enforcement_classification": {
      "additionalProperties": true,
      "properties": {
        "category": {
          "enum": ["penalties", "self_regulatory_measure", "abnormal_operation", "missing_institution", "other_enforcement"]
        },
        "subtype": {
          "enum": ["disciplinary_decision", "disciplinary_prior_notice", "disciplinary_review_decision", "other"]
        }
      },
      "type": ["object", "null"]
    },
    "legal_basis": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "list_summary": {
      "type": [
        "object",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "parties": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "source": {
      "type": "object"
    }
  },
  "required": [
    "metadata",
    "body",
    "legal_basis",
    "parties"
  ],
  "title": "WritDocument",
  "type": "object"
}
