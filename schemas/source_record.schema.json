{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "assets": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "attachment_documents": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "content": {
      "type": "object"
    },
    "discovery_evidence": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "enforcement_classification": {
      "additionalProperties": true,
      "properties": {
        "category": {
          "enum": ["penalties", "self_regulatory_measure", "abnormal_operation", "missing_institution", "other_enforcement"]
        },
        "subtype": {
          "enum": ["disciplinary_decision", "disciplinary_prior_notice", "disciplinary_review_decision", "other"]
        }
      },
      "type": ["object", "null"]
    },
    "fingerprints": {
      "type": "object"
    },
    "ingest_status": {
      "type": "string"
    },
    "material_lane": {
      "type": "string"
    },
    "page_role": {
      "enum": ["normative_instrument", "case_document", "publication_wrapper", "supporting_material", "unknown"]
    },
    "metadata": {
      "type": "object"
    },
    "schema_version": {
      "type": "integer"
    },
    "source": {
      "type": "object"
    },
    "source_record_id": {
      "type": "string"
    },
    "source_system": {
      "type": "string"
    },
    "web_category_leaf": {
      "type": ["string", "null"]
    },
    "web_category_path": {
      "items": {"type": "string"},
      "type": "array"
    },
    "web_category_provenance": {
      "enum": ["page_breadcrumb", "api_channel", "endpoint_profile", "url_inference", null]
    }
  },
  "required": [
    "schema_version",
    "source_record_id",
    "source_system",
    "metadata",
    "content",
    "source"
  ],
  "title": "SourceRecord",
  "type": "object"
}
